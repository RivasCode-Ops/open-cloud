# ============================================
#   Open Cloud — Configuração de Ambiente
# ============================================
# Copie este arquivo para .env e preencha
# com suas chaves reais:
#   cp .env.example .env

# --------------------------------------------
# OpenRouter (obrigatório)
# Obtenha sua key em: https://openrouter.ai/keys
# --------------------------------------------
OPENROUTER_API_KEY=sua_chave_aqui

# --------------------------------------------
# Modelo padrão (opcional)
# Exemplos:
#   anthropic/claude-3-5-sonnet
#   openai/gpt-4o
#   google/gemini-pro
# --------------------------------------------
OPENROUTER_MODEL=anthropic/claude-3-5-sonnet

# --------------------------------------------
# Configurações da aplicação (opcional)
# --------------------------------------------
APP_NAME=Open Cloud
APP_PORT=3000
APP_ENV=development

# --------------------------------------------
# Configurações de debug (opcional)
# --------------------------------------------
DEBUG=false
LOG_LEVEL=info
